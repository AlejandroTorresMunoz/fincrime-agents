# Copy to .env and fill in what you use. Everything here is optional for tests/CI
# (the mock LLM provider and the offline search stub never read any of it).

# Ollama — local LLM runtime serving the base / fine-tuned model.
OLLAMA_BASE_URL=http://localhost:11434

# LangSmith tracing (optional, dev-only debugging of the graph — never enabled in CI).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fincrime-agents

# Tavily web search (optional — `search.provider: offline` stub is the default).
TAVILY_API_KEY=
